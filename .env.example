# asterion — example environment file.
# Copy to `.env` and edit; never commit a real `.env`.

# --- required ----------------------------------------------------------
ASTERION_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/asterion
# Generate via: openssl rand -hex 32
ASTERION_SECRET_KEY=replace-with-32+-random-bytes


# --- app ---------------------------------------------------------------
ASTERION_APP_TITLE=asterion
ASTERION_DEBUG=false


# --- route prefixes ---------------------------------------------------
ASTERION_AUTH_API_PREFIX=/api/v1/auth
ASTERION_ADMIN_API_PREFIX=/api/v1/admin
ASTERION_ROOT_API_PREFIX=/api/v1/root
ASTERION_ADMIN_UI_PATH=/admin


# --- password policy (G21) ---------------------------------------------
ASTERION_PASSWORD_MIN_LENGTH=8
# Check new passwords against Have I Been Pwned (k-anonymity: only a 5-char
# SHA-1 prefix leaves the process). Off by default (external call); needs httpx.
# ASTERION_PASSWORD_HIBP_CHECK=false
# ASTERION_PASSWORD_HIBP_TIMEOUT_SECONDS=3.0


# --- auth / tokens -----------------------------------------------------
ASTERION_JWT_ALGORITHM=HS256
ASTERION_ACCESS_TOKEN_EXPIRE_MINUTES=60
ASTERION_PASSWORD_MIN_LENGTH=8


# --- feature toggles ---------------------------------------------------
ASTERION_ENABLE_BUILTIN_UI=true
ASTERION_ENABLE_BUILTIN_ADMINS=true
ASTERION_ENABLE_MULTI_TENANT=true


# --- tenancy -----------------------------------------------------------
# header | subdomain
ASTERION_TENANT_RESOLUTION=header
ASTERION_TENANT_HEADER_NAME=X-Tenant-Slug


# --- locale defaults --------------------------------------------------
ASTERION_DEFAULT_LANGUAGE=en
ASTERION_DEFAULT_DATE_FORMAT=locale
ASTERION_DEFAULT_DATE_PATTERN=%Y-%m-%d %H:%M
ASTERION_DEFAULT_SHOW_TIMEZONE=false


# --- database pool ----------------------------------------------------
ASTERION_DB_POOL_SIZE=10
ASTERION_DB_MAX_OVERFLOW=20
ASTERION_DB_POOL_PRE_PING=true


# --- logging ----------------------------------------------------------
# CRITICAL / ERROR / WARNING / INFO / DEBUG / NOTSET
ASTERION_LOG_LEVEL=INFO
# Set true in production for structured JSON logs.
ASTERION_LOG_JSON=false


# --- CORS (only used if origins are set) ------------------------------
# Comma-separated list. Empty = no CORS middleware installed.
ASTERION_CORS_ORIGINS=
ASTERION_CORS_ALLOW_CREDENTIALS=false
ASTERION_CORS_ALLOW_METHODS=GET,POST,PATCH,DELETE,OPTIONS
ASTERION_CORS_ALLOW_HEADERS=Authorization,Content-Type,X-Tenant-Slug


# --- security headers -------------------------------------------------
ASTERION_SECURITY_HEADERS_ENABLED=true
# Content-Security-Policy (off by default). With the bundled UI, include the
# literal {nonce} token in script-src — the framework mints a per-request nonce
# and stamps the UI's inline scripts with it (G10), so a strict policy works:
# ASTERION_CONTENT_SECURITY_POLICY=default-src 'self'; script-src 'self' 'nonce-{nonce}'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'


# --- CLI helper (optional) --------------------------------------------
# Lets `asterion permissions sync` discover your FastAPI app without
# explicit --app argument.
# ASTERION_APP=app:app
